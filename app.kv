<ProductDetailsScreen>:
    MDScreen:
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(0)
            padding: dp(0)

            MDBoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(50)
                md_bg_color: bar_blue
                padding: dp(0), 0, dp(4), 0
                MDIconButton:
                    icon: "arrow-left"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    on_release: setattr(app.root, "current", "market")
                    size_hint: None, None
                    size: dp(50), dp(50)
                MDLabel:
                    text: "Detail produit"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    font_style: "H6"
                    size_hint_x: 1
                    halign: "left"
                    valign: "center"
                MDIconButton:
                    icon: "cart"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    on_release: app.open_cart()
                    size_hint: None, None
                    size: dp(50), dp(50)
                    FloatLayout:
                        size: dp(0), dp(0)
                        MDLabel:
                            text: str(app.cart_badge_count) if app.cart_badge_count else ""
                            size_hint: None, None
                            size: dp(18), dp(18)
                            halign: "center"
                            valign: "middle"
                            font_size: "10sp"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            md_bg_color: 0.85, 0.15, 0.2, 1
                            radius: [9, 9, 9, 9]
                            pos_hint: {"right": 0.1, "top": 0.9}
                            opacity: 1 if app.cart_badge_count else 0

            MDCarousel:
                id: image_carousel
                size_hint_y: None
                height: dp(280)
                loop: True
                on_index: root.on_carousel_change()
                
                FitImage:
                    id: d_image
                    size_hint: 1, None
                    height: dp(280)
                    allow_stretch: True
                
                FitImage:
                    id: d_image_2
                    size_hint: 1, None
                    height: dp(280)
                    allow_stretch: True
                    opacity: 0
                
                FitImage:
                    id: d_image_3
                    size_hint: 1, None
                    height: dp(280)
                    allow_stretch: True
                    opacity: 0

            MDBoxLayout:
                size_hint_y: None
                height: dp(30)
                spacing: dp(8)
                padding: dp(12), 0
                MDLabel:
                    text: "Glissez pour voir d'autres angles"
                    theme_text_color: "Hint"
                    font_size: "11sp"
                    size_hint_y: None
                    height: dp(20)

            ScrollView:
                size_hint_y: 1
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(12)
                    padding: dp(16)
                    adaptive_height: True
                    
                    MDLabel:
                        id: d_title
                        text: "Produit"
                        bold: True
                        font_size: "20sp"
                        theme_text_color: "Primary"
                        size_hint_y: None
                        height: self.texture_size[1]
                    
                    MDLabel:
                        id: d_price
                        text: "-"
                        bold: True
                        font_size: "22sp"
                        theme_text_color: "Custom"
                        text_color: 0.13, 0.59, 0.95, 1
                        size_hint_y: None
                        height: dp(30)
                    
                    MDCard:
                        orientation: "horizontal"
                        padding: dp(12)
                        radius: [10, 10, 10, 10]
                        size_hint_y: None
                        height: self.minimum_height
                        
                        MDIcon:
                            icon: "store"
                            theme_text_color: "Primary"
                            size_hint: None, None
                            size: dp(24), dp(24)
                        
                        MDLabel:
                            id: d_shop
                            text: "-"
                            theme_text_color: "Secondary"
                            font_size: "13sp"
                            padding: dp(8), 0
                    
                    MDCard:
                        orientation: "horizontal"
                        padding: dp(12)
                        radius: [10, 10, 10, 10]
                        size_hint_y: None
                        height: self.minimum_height
                        
                        MDIcon:
                            icon: "tag"
                            theme_text_color: "Secondary"
                            size_hint: None, None
                            size: dp(24), dp(24)
                        
                        MDLabel:
                            id: d_category
                            text: "-"
                            theme_text_color: "Secondary"
                            font_size: "13sp"
                            padding: dp(8), 0
                    
                    MDCard:
                        orientation: "horizontal"
                        padding: dp(12)
                        radius: [10, 10, 10, 10]
                        size_hint_y: None
                        height: self.minimum_height
                        
                        MDIcon:
                            icon: "package-variant"
                            theme_text_color: "Custom"
                            text_color: 0.2, 0.7, 0.3, 1
                            size_hint: None, None
                            size: dp(24), dp(24)
                        
                        MDLabel:
                            id: d_stock
                            text: "-"
                            theme_text_color: "Custom"
                            text_color: 0.2, 0.7, 0.3, 1
                            font_size: "13sp"
                            padding: dp(8), 0
                    
                    MDLabel:
                        text: "Description"
                        bold: True
                        font_size: "16sp"
                        theme_text_color: "Primary"
                        size_hint_y: None
                        height: dp(24)
                    
                    MDLabel:
                        id: d_desc
                        text: "-"
                        theme_text_color: "Secondary"
                        font_size: "13sp"
                        size_hint_y: None
                        height: self.texture_size[1]
                        text_size: self.size
                    
                    MDSeparator:
                        height: dp(16)
                    
                    MDLabel:
                        text: "Avis clients"
                        bold: True
                        font_size: "16sp"
                        theme_text_color: "Primary"
                        size_hint_y: None
                        height: dp(24)
                    
                    MDCard:
                        orientation: "horizontal"
                        padding: dp(12)
                        radius: [10, 10, 10, 10]
                        size_hint_y: None
                        height: dp(60)
                        md_bg_color: 0.97, 0.98, 1, 1
                        
                        MDIcon:
                            icon: "star"
                            theme_text_color: "Custom"
                            text_color: 1.0, 0.8, 0.0, 1
                            size_hint: None, None
                            size: dp(28), dp(28)
                        
                        MDLabel:
                            id: d_rating
                            text: "0.0"
                            bold: True
                            font_size: "20sp"
                            theme_text_color: "Primary"
                            padding: dp(8), 0
                        
                        MDLabel:
                            id: d_rating_count
                            text: "(0 avis)"
                            theme_text_color: "Secondary"
                            font_size: "12sp"
                            padding: dp(4), 0
                        
            Widget:

<UpdateScreen>:
    MDScreen:
        md_bg_color: bar_blue

        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(20)
            padding: dp(40)

            Widget:

            MDIcon:
                icon: "cellphone-arrow-down"
                font_size: dp(80)
                size_hint: None, None
                size: dp(80), dp(80)
                pos_hint: {"center_x": 0.5}
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            MDLabel:
                id: update_title
                text: "Mise à jour"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "H4"
                bold: True
                halign: "center"

            MDLabel:
                id: update_desc
                text: ""
                theme_text_color: "Custom"
                text_color: 0.8, 0.9, 1, 1
                font_size: "14sp"
                halign: "center"
                size_hint_y: None
                height: dp(60)

            Widget:

            MDRaisedButton:
                text: "Télécharger"
                md_bg_color: 0.13, 0.61, 0.55, 1
                size_hint_y: None
                height: dp(50)
                on_release: root.do_update()

            MDRaisedButton:
                id: later_btn
                text: "Plus tard"
                md_bg_color: 0.5, 0.5, 0.5, 1
                size_hint_y: None
                height: dp(50)
                on_release: root.do_later()

            MDFlatButton:
                id: quit_btn
                text: "Fermer l'application"
                theme_text_color: "Custom"
                text_color: 0.8, 0.8, 0.8, 1
                size_hint_y: None
                height: dp(40)
                on_release: root.do_quit()

            Widget:
                        
                        MDRaisedButton:
                            id: add_review_btn
                            text: "Laisser un avis"
                            md_bg_color: 0.13, 0.59, 0.95, 1
                            font_size: "11sp"
                            height: dp(36)
                            on_release: root.open_review_dialog()
                    
                    MDCard:
                        orientation: "vertical"
                        padding: dp(12)
                        radius: [10, 10, 10, 10]
                        size_hint_y: None
                        height: self.minimum_height
                        id: reviews_container
                        
                        MDLabel:
                            id: no_reviews
                            text: "Aucun avis pour le moment"
                            theme_text_color: "Hint"
                            font_size: "12sp"
                            halign: "center"
                            size_hint_y: None
                            height: dp(40)
                    
                    Widget:
                        size_hint_y: None
                        height: dp(16)
                    
                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(48)
                        MDTextField:
                            id: d_qty
                            hint_text: "Qte"
                            text: "1"
                            mode: "rectangle"
                            input_filter: "int"
                            size_hint_x: 0.3
                            height: dp(48)
                        MDRaisedButton:
                            text: "Ajouter au panier"
                            md_bg_color: 0.13, 0.61, 0.55, 1
                            font_size: "14sp"
                            on_release: root.request_add_to_cart()
                    
                    MDLabel:
                        text: root.message
                        theme_text_color: "Error"
                        size_hint_y: None
                        height: dp(24)
                    
                    Widget:
                        size_hint_y: None
                        height: dp(20)

<CartScreen>:
    MDScreen:
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(0)
            padding: dp(0)
            md_bg_color: 0.96, 0.97, 0.98, 1
            
            MDBoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(50)
                md_bg_color: bar_blue
                padding: dp(0), 0, dp(4), 0
                MDIconButton:
                    icon: "arrow-left"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    on_release: setattr(app.root, "current", "market")
                    size_hint: None, None
                    size: dp(50), dp(50)
                MDLabel:
                    text: "Mon Panier"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    font_style: "H6"
                    size_hint_x: 1
                    halign: "left"
                    valign: "center"
            
            MDCard:
                size_hint_y: None
                height: dp(60)
                md_bg_color: 0.13, 0.59, 0.95, 1
                radius: [0, 0, 0, 0]
                padding: dp(16)
                MDLabel:
                    id: cart_total
                    text: "Total: 0.00 credits"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    font_style: "H6"
                    bold: True
            
            ScrollView:
                size_hint_y: 1
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(10)
                    padding: dp(12)
                    adaptive_height: True
                    
                    MDGridLayout:
                        id: cart_items
                        cols: 1
                        adaptive_height: True
                        spacing: dp(10)
            
            MDLabel:
                text: root.message
                theme_text_color: "Error"
                halign: "center"
                size_hint_y: None
                height: dp(24)
            
            MDBoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(56)
                spacing: dp(8)
                padding: dp(12), dp(8)
                MDRaisedButton:
                    text: "Vider le panier"
                    md_bg_color: 0.75, 0.75, 0.75, 1
                    on_release: root.clear_cart()
                MDRaisedButton:
                    text: "Commander"
                    md_bg_color: 0.13, 0.59, 0.95, 1
                    on_release: root.commander()

<OrdersScreen>:
    MDScreen:
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(0)
            padding: dp(0)
            md_bg_color: 0.96, 0.97, 0.98, 1
            
            MDBoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(50)
                md_bg_color: bar_blue
                padding: dp(0), 0, dp(4), 0
                MDIconButton:
                    icon: "arrow-left"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    on_release: setattr(app.root, "current", "market")
                    size_hint: None, None
                    size: dp(50), dp(50)
                MDLabel:
                    text: "Mes commandes"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    font_style: "H6"
                    size_hint_x: 1
                    halign: "left"
                    valign: "center"
            
            MDLabel:
                text: root.message
                theme_text_color: "Secondary"
                halign: "center"
                size_hint_y: None
                height: dp(24)
            
            ScrollView:
                size_hint_y: 1
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(10)
                    padding: dp(12)
                    adaptive_height: True
                    
                    MDGridLayout:
                        id: client_orders
                        cols: 1
                        adaptive_height: True
                        spacing: dp(10)

<AccountScreen>:
    MDScreen:
        MDBoxLayout:
            orientation: "vertical"
            padding: dp(10)
            spacing: dp(8)
            MDTopAppBar:
                title: "Mon Compte"
                elevation: 2
                md_bg_color: bar_blue
                specific_text_color: bar_text
                left_action_items: [["arrow-left", lambda x: setattr(app.root, "current", "market")]]
            ScrollView:
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(16)
                    adaptive_height: True
                    padding: dp(12)
                    
                    # Avatar et nom
                    MDCard:
                        orientation: "vertical"
                        padding: dp(20)
                        spacing: dp(12)
                        size_hint_y: None
                        height: dp(180)
                        md_bg_color: 0.13, 0.59, 0.95, 1
                        
                        MDIcon:
                            icon: "account-circle"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_size: dp(80)
                            size_hint: None, None
                            size: dp(80), dp(80)
                            pos_hint: {"center_x": 0.5}
                        
                        MDLabel:
                            id: profile_name_header
                            text: "Utilisateur"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1
                            font_style: "H5"
                            bold: True
                            halign: "center"
                            size_hint_y: None
                            height: dp(30)
                        
                        MDLabel:
                            id: profile_email_header
                            text: "email@example.com"
                            theme_text_color: "Custom"
                            text_color: 0.9, 0.95, 1, 1
                            font_style: "Caption"
                            halign: "center"
                            size_hint_y: None
                            height: dp(20)
                    
                    # Informations personnelles
                    MDCard:
                        orientation: "vertical"
                        padding: dp(16)
                        spacing: dp(12)
                        size_hint_y: None
                        height: self.minimum_height
                        md_bg_color: 1, 1, 1, 1
                        
                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(24)
                            spacing: dp(8)
                            MDIcon:
                                icon: "information"
                                theme_text_color: "Custom"
                                text_color: 0.13, 0.59, 0.95, 1
                                size_hint: None, None
                                size: dp(24), dp(24)
                            MDLabel:
                                text: "Informations personnelles"
                                font_style: "H6"
                                theme_text_color: "Custom"
                                text_color: 0.2, 0.2, 0.2, 1
                                size_hint_y: None
                                height: dp(24)
                        
                        MDSeparator:
                            size_hint_y: None
                            height: dp(1)
                            color: 0.9, 0.9, 0.9, 1
                        
                        # Nom complet
                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(56)
                            spacing: dp(12)
                            MDIcon:
                                icon: "account"
                                theme_text_color: "Custom"
                                text_color: 0.5, 0.5, 0.5, 1
                                size_hint: None, None
                                size: dp(24), dp(24)
                            MDTextField:
                                id: acc_name
                                hint_text: "Nom complet"
                                mode: "rectangle"
                                size_hint_y: None
                                height: dp(56)
                                icon_left: "account-edit"
                        
                        # Email
                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(56)
                            spacing: dp(12)
                            MDIcon:
                                icon: "email"
                                theme_text_color: "Custom"
                                text_color: 0.5, 0.5, 0.5, 1
                                size_hint: None, None
                                size: dp(24), dp(24)
                            MDTextField:
                                id: acc_email
                                hint_text: "Email"
                                mode: "rectangle"
                                readonly: True
                                size_hint_y: None
                                height: dp(56)
                                icon_left: "lock"
                        
                        # Téléphone
                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(56)
                            spacing: dp(12)
                            MDIcon:
                                icon: "phone"
                                theme_text_color: "Custom"
                                text_color: 0.5, 0.5, 0.5, 1
                                size_hint: None, None
                                size: dp(24), dp(24)
                            MDTextField:
                                id: acc_phone
                                hint_text: "Téléphone"
                                mode: "rectangle"
                                size_hint_y: None
                                height: dp(56)
                                icon_left: "phone-edit"
                        
                        # Adresse
                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(56)
                            spacing: dp(12)
                            MDIcon:
                                icon: "map-marker"
                                theme_text_color: "Custom"
                                text_color: 0.5, 0.5, 0.5, 1
                                size_hint: None, None
                                size: dp(24), dp(24)
                            MDTextField:
                                id: acc_address
                                hint_text: "Adresse"
                                mode: "rectangle"
                                size_hint_y: None
                                height: dp(56)
                                icon_left: "pencil"
                        
                        # Date de naissance
                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(56)
                            spacing: dp(12)
                            MDIcon:
                                icon: "calendar"
                                theme_text_color: "Custom"
                                text_color: 0.5, 0.5, 0.5, 1
                                size_hint: None, None
                                size: dp(24), dp(24)
                            MDTextField:
                                id: acc_birth_date
                                hint_text: "Date de naissance"
                                mode: "rectangle"
                                readonly: True
                                size_hint_y: None
                                height: dp(56)
                                icon_left: "lock"
                        
                        # Genre
                        MDBoxLayout:
                            orientation: "horizontal"
                            size_hint_y: None
                            height: dp(56)
                            spacing: dp(12)
                            MDIcon:
                                icon: "gender-male-female"
                                theme_text_color: "Custom"
                                text_color: 0.5, 0.5, 0.5, 1
                                size_hint: None, None
                                size: dp(24), dp(24)
                            MDTextField:
                                id: acc_gender
                                hint_text: "Genre"
                                mode: "rectangle"
                                readonly: True
                                size_hint_y: None
                                height: dp(56)
                                icon_left: "lock"
                        
                        MDSeparator:
                            size_hint_y: None
                            height: dp(8)
                        
                        # Bouton sauvegarder
                        MDRaisedButton:
                            text: "Sauvegarder les modifications"
                            md_bg_color: 0.13, 0.59, 0.95, 1
                            text_color: 1, 1, 1, 1
                            on_release: root.save_profile()
                            size_hint_x: 1
                            size_hint_y: None
                            height: dp(50)
                    
                    # Message
                    MDLabel:
                        id: message_label
                        text: root.message
                        theme_text_color: "Error"
                        halign: "center"
                        size_hint_y: None
                        height: dp(30)
                        opacity: 1 if root.message else 0

<ContactAdminScreen>:
    MDScreen:
        MDBoxLayout:
            orientation: "vertical"
            
            MDTopAppBar:
                title: "Contacter Admin"
                elevation: 2
                md_bg_color: bar_blue
                specific_text_color: bar_text
                left_action_items: [["arrow-left", lambda x: setattr(app.root, "current", "market")]]
            
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(16)
                spacing: dp(12)
                
                MDLabel:
                    text: "Envoyer un message à l'admin"
                    bold: True
                    font_size: "18sp"
                    size_hint_y: None
                    height: dp(30)
                    halign: "center"
                
                MDTextField:
                    id: contact_subject
                    hint_text: "Sujet"
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(50)
                
                MDTextField:
                    id: contact_message
                    hint_text: "Votre message..."
                    mode: "rectangle"
                    multiline: True
                    size_hint_y: 1
                
                MDRaisedButton:
                    text: "Envoyer"
                    md_bg_color: 0.13, 0.59, 0.95, 1
                    size_hint_y: None
                    height: dp(50)
                    on_release: root.send_message()
                
                MDLabel:
                    text: root.message
                    theme_text_color: "Custom"
                    text_color: 0.13, 0.59, 0.95, 1
                    halign: "center"
                    size_hint_y: None
                    height: dp(24)
                
                MDLabel:
                    text: "Mes messages"
                    bold: True
                    font_size: "16sp"
                    size_hint_y: None
                    height: dp(30)
                
                ScrollView:
                    size_hint_y: 2
                    do_scroll_x: False
                    
                    MDBoxLayout:
                        id: messages_container
                        orientation: "vertical"
                        spacing: dp(10)
                        adaptive_height: True
                        size_hint_x: 1

<VerificationScreen>:
    MDScreen:
        md_bg_color: 0.96, 0.97, 0.98, 1
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(0)
            padding: dp(0)

            MDTopAppBar:
                title: "Verification email"
                elevation: 2
                md_bg_color: bar_blue
                specific_text_color: bar_text

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(16)
                padding: dp(24)
                adaptive_height: True
                size_hint_y: None
                pos_hint: {"center_x": 0.5, "center_y": 0.5}

                FitImage:
                    source: "img/logo.png"
                    size_hint: None, None
                    size: dp(80), dp(80)
                    pos_hint: {"center_x": 0.5}
                    radius: [12, 12, 12, 12]

                MDLabel:
                    text: "Verification email"
                    font_style: "H5"
                    bold: True
                    halign: "center"
                    size_hint_y: None
                    height: dp(36)

                MDLabel:
                    text: "Un code a 6 chiffres a ete envoye a votre adresse email."
                    theme_text_color: "Secondary"
                    halign: "center"
                    size_hint_y: None
                    height: dp(40)
                    font_size: "13sp"

                MDLabel:
                    id: debug_code_label
                    text: ""
                    theme_text_color: "Hint"
                    halign: "center"
                    size_hint_y: None
                    height: dp(20)
                    font_size: "11sp"

                MDTextField:
                    id: code_input
                    hint_text: "Code a 6 chiffres"
                    mode: "rectangle"
                    input_filter: "int"
                    max_text_length: 6
                    size_hint_y: None
                    height: dp(56)
                    halign: "center"
                    font_size: "24sp"

                MDLabel:
                    text: root.message
                    theme_text_color: "Error"
                    halign: "center"
                    size_hint_y: None
                    height: dp(30)

                MDRaisedButton:
                    text: "Verifier"
                    md_bg_color: 0.13, 0.59, 0.95, 1
                    on_release: root.verify_code()
                    size_hint_y: None
                    height: dp(50)

                MDFlatButton:
                    text: "Renvoyer le code"
                    theme_text_color: "Custom"
                    text_color: 0.13, 0.59, 0.95, 1
                    on_release: root.resend_code()
                    disabled: not root.can_resend
                    size_hint_y: None
                    height: dp(40)

<ForgotPasswordScreen>:
    MDScreen:
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(0)
            padding: dp(0)

            MDBoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(50)
                md_bg_color: bar_blue
                padding: dp(0), 0, dp(4), 0
                MDIconButton:
                    icon: "arrow-left"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    on_release: app.root.current = "login"
                    size_hint: None, None
                    size: dp(50), dp(50)
                MDLabel:
                    text: "Mot de passe oublie"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    font_style: "H6"
                    size_hint_x: 1
                    halign: "left"
                    valign: "center"

            ScrollView:
                size_hint_y: 1
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(12)
                    padding: dp(16)
                    adaptive_height: True

                    MDLabel:
                        text: "Entrez votre adresse email pour recevoir un code de reinitialisation."
                        theme_text_color: "Secondary"
                        halign: "center"
                        size_hint_y: None
                        height: dp(40)
                        font_size: "13sp"

                    MDTextField:
                        id: forgot_email
                        hint_text: "Adresse email"
                        mode: "rectangle"

                    MDLabel:
                        text: root.message
                        theme_text_color: "Error"
                        halign: "center"
                        size_hint_y: None
                        height: dp(30)

                    MDRaisedButton:
                        text: "Envoyer le code"
                        md_bg_color: 0.13, 0.59, 0.95, 1
                        on_release: root.send_reset_code()
                        size_hint_y: None
                        height: dp(50)

<ResetPasswordScreen>:
    MDScreen:
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(0)
            padding: dp(0)

            MDBoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(50)
                md_bg_color: bar_blue
                padding: dp(0), 0, dp(4), 0
                MDIconButton:
                    icon: "arrow-left"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    on_release: app.root.current = "forgot_password"
                    size_hint: None, None
                    size: dp(50), dp(50)
                MDLabel:
                    text: "Nouveau mot de passe"
                    theme_text_color: "Custom"
                    text_color: bar_text
                    font_style: "H6"
                    size_hint_x: 1
                    halign: "left"
                    valign: "center"

            ScrollView:
                size_hint_y: 1
                MDBoxLayout:
                    orientation: "vertical"
                    spacing: dp(12)
                    padding: dp(16)
                    adaptive_height: True

                    MDLabel:
                        text: "Un code a 6 chiffres a ete envoye a votre email."
                        theme_text_color: "Secondary"
                        halign: "center"
                        size_hint_y: None
                        height: dp(40)
                        font_size: "13sp"

                    MDTextField:
                        id: reset_code
                        hint_text: "Code a 6 chiffres"
                        mode: "rectangle"
                        input_filter: "int"
                        max_text_length: 6

                    MDTextField:
                        id: reset_password
                        hint_text: "Nouveau mot de passe"
                        password: True
                        mode: "rectangle"

                    MDTextField:
                        id: reset_confirm
                        hint_text: "Confirmer le mot de passe"
                        password: True
                        mode: "rectangle"

                    MDLabel:
                        text: root.message
                        theme_text_color: "Error"
                        halign: "center"
                        size_hint_y: None
                        height: dp(30)

                    MDRaisedButton:
                        text: "Reinitialiser"
                        md_bg_color: 0.13, 0.59, 0.95, 1
                        on_release: root.reset_password()
                        size_hint_y: None
                        height: dp(50)

