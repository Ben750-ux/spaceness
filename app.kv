<HistoryScreen>:
    MDScreen:
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(0)
            padding: dp(0)
            md_bg_color: 0.96, 0.97, 0.98, 1
            
            MDBoxLayout:
                orientation: "horizontal"
