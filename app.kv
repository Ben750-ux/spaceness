<LoadingScreen>:
    MDScreen:
        md_bg_color: bar_blue
        
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(20)
            padding: dp(40)
            
            Widget:
            
            FitImage:
                source: "img/logo.png"
                size_hint: None, None
                size: dp(120), dp(120)
                pos_hint: {"center_x": 0.5}
                radius: [20, 20, 20, 20]
            
            MDLabel:
                text: "Spaceness"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "H4"
                bold: True
                halign: "center"
            
            MDLabel:
                text: "Marketplace"
                theme_text_color: "Custom"
                text_color: 0.8, 0.9, 1, 1
                font_style: "Subtitle1"
                halign: "center"
            
            Widget:
            
            MDSpinner:
                size_hint: None, None
                size: dp(40), dp(40)
                pos_hint: {"center_x": 0.5}
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
            
            MDLabel:
